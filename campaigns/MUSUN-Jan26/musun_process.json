{   "comment":"Do something with musun samples",
    "inputs":{
        "skip":0,
        "limit":1000
    },
    "sites":{
        "allowed_sites":[
            "US_FNAL-FermiGrid",
            "CERN",
            "FR_CCIN2P3"]
        },
    "output":{
        "name": "{core.run_type}__{core.data_tier}__{dune.campaign}__{dune.config_file}__{core.application.name}__{core.application.version}__{merge.cfg}__{$DUNESW_VERSION}",
        "namespace": "usertests",
        "dir": "/pnfs/dune/scratch/users/${USER}/merge_test/example/"    
    },

    "metadata":{
        "required":["~core.runs"]
    },

    "sites":{
        "rse_distances":{
            "FNAL_DCACHE": 1001,
            "DUNE_US_FNAL_DISK_STAGE":1
        }
    },

    "merging":{
        "method":{
            "name": "lar",
            "cmd": "lar -c {cfg} -n 1000000 {inputs}",
            "cfg": "triggerana_dune10kt_1x2x2.fcl",
            "outputs": [
                {
                    "name": "{NAME}__ntuple__{UUID}.root",
                    "rename": "triggerAna.ntuple.root",
                    "metadata": {
                        "core.data_tier": "root-tuple-virtual",
                        "core.application.name": "triggerAna",
                        "core.file_format": "root",
                        "dune.campaign": "test_campaign"
                    },
                    "method": "hadd"
                }
            ]
        },
        "target_mode": "count",
        "target_size": 4000,
        "chunk_max": 100
    }
}
